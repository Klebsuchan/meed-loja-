rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /products/{productId} {
      allow read: if true;
      allow write: if true;
    }
    match /orders/{orderId} {
      allow read: if true;
      allow write: if true;
    }
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if true;
    }
    match /carts/{cartId} {
      allow read: if true;
      allow write: if true;
    }
    match /mail/{mailId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
